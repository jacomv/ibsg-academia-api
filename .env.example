# ─── IBSG Academia API — Variables de entorno para producción ────────────────
# Copiar este archivo como referencia al configurar las env vars en Dokploy.
# NUNCA subir este archivo con valores reales.

# ─── Base de datos ────────────────────────────────────────────────────────────
# Formato: Host=HOST;Port=5432;Database=DB;Username=USER;Password=PASS
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=academia_db;Username=academia_user;Password=CAMBIA_ESTO

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres, aleatorio y seguro
JwtSettings__SecretKey=GENERA_UNA_CLAVE_ALEATORIA_MUY_LARGA_AQUI
JwtSettings__Issuer=ibsg-academia-api
JwtSettings__Audience=ibsg-academia-frontend
JwtSettings__AccessTokenExpirationMinutes=60
JwtSettings__RefreshTokenExpirationDays=7

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: usa una "App Password" (no la contraseña normal)
# https://myaccount.google.com/apppasswords
EmailSettings__SmtpHost=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__UseSsl=false
EmailSettings__Username=academia@ibsg.app
EmailSettings__Password=TU_APP_PASSWORD_DE_GMAIL
EmailSettings__FromEmail=academia@ibsg.app
EmailSettings__FromName=IBSG Academia

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL del frontend (para links en emails de reset password, certificados, etc.)
AppSettings__FrontendUrl=https://academia.ibsg.app

# ─── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_HTTP_PORTS=8080
